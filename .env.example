SEMANTIC_CACHE_THRESHOLD=0.90 # Default similarity threshold for cache hit (0.0–1.0)
SEMANTIC_CACHE_PG_URI=postgresql://user:pass@localhost:5432/semanticcache # PostgreSQL URI with pgvector extension
SEMANTIC_CACHE_REDIS_URI=redis://localhost:6379/0 # Redis URI for cache TTL
SEMANTIC_CACHE_REDIS_TTL_SECONDS=3600 # Default TTL for Redis-cached responses (seconds)
SEMANTIC_CACHE_PG_POOL_SIZE=10 # Default pool size for PostgreSQL connection pool
SEMANTIC_CACHE_PG_POOL_MAX_OVERFLOW=20 # Default max overflow for PostgreSQL connection pool
SEMANTIC_CACHE_EMBEDDER_TYPE=huggingface # Default embedder type (huggingface, openai, cohere, voyage, ollama)
SEMANTIC_CACHE_PROXY_UPSTREAM=http://127.0.0.1:11434 # Default upstream URL for reverse proxy

# Optional:
OPENAI_API_KEY=your-openai-api-key # optional OpenAI API key for OpenAI embeddings
COHERE_API_KEY=your-cohere-api-key # optional Cohere API key for Cohere embeddings
VOYAGE_API_KEY=your-voyage-api-key # optional Voyage API key for Voyage embeddings
HUGGINGFACE_API_KEY=your-huggingface-api-key # optional Hugging Face API key for private models and rate limiting
OLLAMA_API_KEY=your-ollama-api-key # optional Ollama API key for Ollama embeddings