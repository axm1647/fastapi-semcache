SEMANTIC_CACHE_THRESHOLD=0.90 # Primary similarity threshold for candidate inclusion (0.0–1.0)
SEMANTIC_CACHE_TOP_K_CANDIDATES=1 # Maximum number of nearest-neighbor candidates fetched before final similarity decision
SEMANTIC_CACHE_REJECTION_THRESHOLD= # Optional stricter second-stage similarity threshold; when set, candidates below this are treated as a miss
SEMANTIC_CACHE_PG_URI=postgresql://user:pass@localhost:5432/semanticcache # PostgreSQL URI with pgvector extension
SEMANTIC_CACHE_REDIS_URI=redis://localhost:6379/0 # Redis URI for cache TTL (empty/whitespace disables Redis and uses Postgres-only response storage)
SEMANTIC_CACHE_REDIS_TTL_SECONDS=3600 # Default TTL for Redis-cached responses (seconds)
SEMANTIC_CACHE_PG_POOL_SIZE=10 # Default pool size for PostgreSQL connection pool
SEMANTIC_CACHE_PG_POOL_MAX_OVERFLOW=20 # Default max overflow for PostgreSQL connection pool
SEMANTIC_CACHE_EMBED_TIMEOUT_SECONDS=10.0 # Timeout budget for embedder calls in seconds (empty to disable)
SEMANTIC_CACHE_STORE_TIMEOUT_SECONDS=5.0 # Timeout budget for Postgres/Redis operations in seconds (empty to disable)
SEMANTIC_CACHE_EMBEDDER_TYPE=huggingface # Default embedder type (huggingface, openai, cohere, voyage, ollama). You can also use a custom embedder by implementing the BaseEmbedder class and passing it to the SemanticCache constructor instead.
# When true (default), cache lookups and writes require a non-empty tenant/namespace scope
# (middleware: X-Semantic-Cache-Scope header or JSON cache_scope / tenant_id). Set false
# only for dedicated single-tenant deployments. See docs/cache-tuning.md.
# SEMANTIC_CACHE_REQUIRE_CACHE_SCOPE=true
SEMANTIC_CACHE_PROXY_UPSTREAM=http://127.0.0.1:11434 # Default upstream URL for reverse proxy

# Optional:
OPENAI_API_KEY=your-openai-api-key # optional OpenAI API key for OpenAI embeddings
COHERE_API_KEY=your-cohere-api-key # optional Cohere API key for Cohere embeddings
VOYAGE_API_KEY=your-voyage-api-key # optional Voyage API key for Voyage embeddings
HUGGINGFACE_API_KEY=your-huggingface-api-key # optional Hugging Face API key for private models and rate limiting
OLLAMA_API_KEY=your-ollama-api-key # optional Ollama API key when embedder_type is ollama and the server expects a Bearer token
# Required when SEMANTIC_CACHE_EMBEDDER_TYPE=ollama (model output width must match pgvector):
# SEMANTIC_CACHE_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# SEMANTIC_CACHE_OLLAMA_EMBEDDING_DIMENSIONS=768
# SEMANTIC_CACHE_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1 # OpenAI-compatible root including /v1

# Optional: after enough consecutive upstream HTTP 429 responses, stop forwarding and
# only serve cache hits until cooldown (FastAPI middleware / proxy). Off by default.
# SEMANTIC_CACHE_CIRCUIT_BREAKER_429_ENABLED=false
# SEMANTIC_CACHE_CIRCUIT_BREAKER_429_CONSECUTIVE_LIMIT=5
# SEMANTIC_CACHE_CIRCUIT_BREAKER_429_OPEN_SECONDS=60

# Optional: cap in-memory per-key middleware flight locks used to coordinate
# concurrent misses for the same (query, model). Oldest unlocked locks are evicted.
# SEMANTIC_CACHE_MIDDLEWARE_FLIGHT_LOCK_MAX_ENTRIES=4096